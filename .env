# Database URLs
DATABASE_URL=postgresql://postgres:2846@localhost:5432/riwi_interventions
MONGODB_URL=mongodb://localhost:27017/riwi_records

# Security
SECRET_KEY=your-super-secret-key-here-change-in-production-please-use-strong-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# AI Integration
OPENAI_API_KEY=sk-your-openai-api-key-here

# CORS (for development)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:8000

# Security Settings
RATE_LIMIT_PER_MINUTE=100
MAX_AUDIO_FILE_SIZE_MB=50

# Logging
LOG_LEVEL=INFO
LOG_TO_FILE=true
LOG_TO_CONSOLE=true

# Database Connection Pooling
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# Frontend Configuration
API_BASE_URL=http://localhost:8000

# Development Settings
DEBUG=true
RELOAD=true
