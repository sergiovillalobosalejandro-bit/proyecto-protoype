DATABASE_URL=postgresql://username:password@localhost:5432/clinical_interventions
MONGODB_URL=mongodb://localhost:27017/clinical_records
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
OPENAI_API_KEY=your-openai-api-key

# CORS Configuration (comma-separated origins for production)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Security Settings
RATE_LIMIT_PER_MINUTE=100
MAX_AUDIO_FILE_SIZE_MB=50

# Logging Configuration
LOG_LEVEL=INFO
LOG_TO_FILE=true
LOG_TO_CONSOLE=true

# Frontend Configuration
API_URL=http://localhost:8000/api
APP_NAME=Sistema de Intervenciones Clínicas
APP_VERSION=1.0.0

# Database Connection Pooling
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# MongoDB Settings
MONGO_POOL_SIZE=10
MONGO_MAX_POOL_SIZE=100
